        <!--  BUTTON RIPPLE EFFECT ON HOVER  -->
        <script>
document.addEventListener("DOMContentLoaded", function() {
  const rippleButtons = document.querySelectorAll(".pr_button");
  rippleButtons.forEach(button => {
    // Create the ripple element if it doesn't exist
    let ripple = button.querySelector(".pr_button_circle");
    if (!ripple) {
      ripple = document.createElement("div");
      ripple.classList.add("pr_button_circle");
      button.appendChild(ripple);
    }
    // When mouse enters the button
    button.addEventListener("mouseenter", function(e) {
      const rect = button.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      // Set the ripple position
      ripple.style.left = `${x}px`;
      ripple.style.top = `${y}px`;
      // Reset animation
      ripple.style.transition = "none";
      ripple.style.transform = "translate(-50%, -50%) scale(0)";
      ripple.style.opacity = "0";
      // Force reflow
      void ripple.offsetWidth;
      // Start the grow animation
      ripple.style.transition = "transform 0.6s ease, opacity 0.6s ease";
      ripple.style.transform = "translate(-50%, -50%) scale(10)"; // Larger scale to cover button
      ripple.style.opacity = "1";
    });
    // When mouse leaves the button
    button.addEventListener("mouseleave", function(e) {
      const rect = button.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      // Update position to where cursor left
      ripple.style.left = `${x}px`;
      ripple.style.top = `${y}px`;
      // Start the shrink animation
      ripple.style.opacity = "0";
      ripple.style.transform = "translate(-50%, -50%) scale(0)";
    });
  });
});
</script>
