  // Remove event listeners
  document.removeEventListener('wheel', preventScroll);
  document.removeEventListener('touchmove', preventScroll);
  document.removeEventListener('keydown', preventScrollKeys);
  // Unlock body scroll
  document.body.style.overflow = '';
  document.documentElement.style.overflow = '';
}
function preventScroll(e) {
  e.preventDefault();
  e.stopPropagation();
  return false;
}
function preventScrollKeys(e) {
  const keys = [32, 33, 34, 35, 36, 37, 38, 39, 40]; // space, page up/down, end, home, arrow keys
  if (keys.includes(e.keyCode)) {
    e.preventDefault();
    return false;
  }
}
barba.init({
  debug: true,
  scroll: false,
  transitions: [
    {
      name: 'works-to-detail',
      from: { namespace: ['works'] },
      to: { namespace: ['work-detail'] },
      // Only apply this transition to elements with data-image-id
      custom: ({ trigger }) => {
        return trigger && trigger.hasAttribute('data-image-id');
      },
      async leave(data) {
        console.log('[Barba] leave works → detail');
        // 🔒 LOCK SCROLL IMMEDIATELY
        lockScroll();
        const done = this.async();
        const imageId = data.trigger?.dataset?.imageId;
        const fromImage = data.current.container.querySelector(`img[data-image-id="${imageId}"]`);
        if (!fromImage) {
          unlockScroll(); // Unlock if no image found
          return done();
        }
        // Measure position BEFORE any changes
        const rect = fromImage.getBoundingClientRect();
        // Clone the image
        const clone = fromImage.cloneNode(true);
        Object.assign(clone.style, {
          position: 'fixed',
          top: `${rect.top}px`,
          left: `${rect.left}px`,
          width: `${rect.width}px`,
          height: `${rect.height}px`,
          zIndex: 9999,
          objectFit: 'cover',
          pointerEvents: 'none',
          margin: 0
        });
        document.body.appendChild(clone);
        data.clone = clone;
        data.imageId = imageId;
        // Create overlay
        const overlay = document.createElement('div');
        Object.assign(overlay.style, {
          position: 'fixed',
          top: 0,
          left: 0,
          width: '100vw',
          height: '100vh',
          backgroundColor: 'var(--background--light)',
          opacity: 0,
          zIndex: 9998,
          pointerEvents: 'none'
        });
        overlay.classList.add('barba-transition-overlay');
        document.body.appendChild(overlay);
        data.overlay = overlay;
        // Animate overlay fade-in
        await gsap.to(overlay, {
          opacity: 1,
          duration: 0.3,
          ease: 'power2.out'
        });
        // Force body background
        document.body.style.setProperty('background-color', 'var(--background--light)', 'important');
        // Scroll to top AFTER locking scroll
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        // Begin fading out current container
        data.current.container.classList.add('barba-container-transitioning');
        await gsap.to(data.current.container, {
          opacity: 0,
          duration: 0.3,
          ease: 'power2.out'
        });
        done();
      },
      async enter(data) {
        console.log('[Barba] enter work-detail');
        const nextContainer = data.next.container;
        const clone = data.clone;
        const imageId = data.imageId;
        // Keep scroll locked during enter phase
        if (!clone || !imageId) {
          gsap.set(nextContainer, { opacity: 1 });
          // 🔓 UNLOCK SCROLL
          unlockScroll();
          return;
        }
        gsap.set(nextContainer, { opacity: 0 });
        let toImage = null;
        for (let i = 0; i < 15; i++) {
          await new Promise(r => setTimeout(r, 66));
          toImage = data.next.container.querySelector(`img.is-work[data-image-id="${imageId}"]`);
          if (toImage && toImage.offsetWidth > 0) break;
        }
        if (!toImage) {
          clone.remove();
          data.overlay?.remove();
          gsap.set(nextContainer, { opacity: 1 });
          // 🔓 UNLOCK SCROLL
          unlockScroll();
          return;
        }
        await new Promise(resolve => requestAnimationFrame(resolve));
        const rect = toImage.getBoundingClientRect();
        await gsap.to(clone, {
          top: rect.top,
          left: rect.left,
          width: rect.width,
          height: rect.height,
          duration: 0.7,
          ease: 'power2.inOut'
        });
        await gsap.to(nextContainer, {
          opacity: 1,
          duration: 0.4,
          ease: 'power2.out'
        });
        clone.remove();
        data.overlay?.remove();
        // 🔓 UNLOCK SCROLL - Wait a bit to ensure everything is settled
        setTimeout(() => {
          unlockScroll();
        }, 100);
      }
    }
  ],
  prevent: ({ el, current }) => {
    const fromNamespace = current?.namespace;
    // Only prevent if leaving from work-detail (your original logic)
    if (fromNamespace === 'work-detail') {
      console.log('[Barba] Prevented: Leaving work-detail, fallback to default browser');
      return true;
    }
    // Let Barba handle links with data-image-id, prevent everything else
    if (el && !el.hasAttribute('data-image-id')) {
      console.log('[Barba] Prevented: Not an image link, using default navigation');
      return true;
    }
    return false;
  }
});
