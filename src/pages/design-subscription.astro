        <script>
function initNavbarTheme() {
  const navbar = document.querySelector('.navbar');
  const triggerLine1 = document.querySelector('.nav_mobile-trigger_line1');
  const triggerLine2 = document.querySelector('.nav_mobile-trigger_line2');
  if (!navbar || !triggerLine1 || !triggerLine2) return; // prevent crash
  let currentTheme = null;
  const OFFSET = 40;
  function getSectionAtTop() {
    const themeSections = document.querySelectorAll('[data-theme]');
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top <= OFFSET && rect.bottom > OFFSET) return section;
    }
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) return section;
    }
    return null;
  }
  function updateNavbarTheme() {
    const topSection = getSectionAtTop();
    if (!topSection) return;
    const theme = topSection.getAttribute('data-theme');
    if (theme !== currentTheme) {
      currentTheme = theme;
      navbar.style.transition = 'background-color 0.3s, color 0.3s';
      if (theme === 'light') {
        navbar.style.backgroundColor = 'var(--background--light)';
        navbar.style.color = 'var(--text-color--primary-dark)';
        triggerLine1.style.backgroundColor = 'var(--background--dark)';
        triggerLine2.style.backgroundColor = 'var(--background--dark)';
      } else if (theme === 'dark') {
        navbar.style.backgroundColor = 'var(--background--dark)';
        navbar.style.color = 'var(--text-color--primary-light)';
        triggerLine1.style.backgroundColor = 'var(--background--light)';
        triggerLine2.style.backgroundColor = 'var(--background--light)';
      } else if (theme === 'transparent') {
        navbar.style.backgroundColor = 'transparent';
        navbar.style.color = 'var(--text-color--primary-light)';
        triggerLine1.style.backgroundColor = 'var(--background--light)';
        triggerLine2.style.backgroundColor = 'var(--background--light)';
      }
    }
  }
  updateNavbarTheme();
  window.addEventListener('scroll', () => {
    requestAnimationFrame(updateNavbarTheme);
  });
}
function initMobileMenu() {
  const trigger = document.querySelector(".nav_mobile-trigger");
  const navMenu = document.querySelector(".nav_mobile-menu");
  const navLogo = document.querySelector(".nav_logo-wrap");
  if (!trigger || !navMenu || !navLogo) return;
  function toggleMenu(isOpen) {
    trigger.classList.toggle("active", isOpen);
    navLogo.classList.toggle("active", isOpen);
    if (isOpen) {
      navMenu.classList.add("active");
      navMenu.style.visibility = "visible";
      if (window.lenis) window.lenis.stop();
    } else {
      navMenu.classList.remove("active");
      if (window.lenis) window.lenis.start();
      setTimeout(() => {
        if (!navMenu.classList.contains("active")) {
          navMenu.style.visibility = "hidden";
        }
      }, 500);
    }
  }
  document.addEventListener("click", function (e) {
    const isTrigger = trigger.contains(e.target);
    const isNavList = navMenu.contains(e.target);
    if (isTrigger) {
      const isActive = navMenu.classList.contains("active");
      toggleMenu(!isActive);
    } else if (!isNavList && navMenu.classList.contains("active")) {
      toggleMenu(false);
    }
  });
}
function initInternalLinks() {
  const links = document.querySelectorAll('[internal-link]');
  const isOnWorkDetail = document.querySelector('[data-barba-namespace="work-detail"]');
  links.forEach(link => {
    const colorValue = link.getAttribute('internal-link');
    if (!colorValue) return;
    // Prevent Barba from hijacking the link if on work-detail
    if (isOnWorkDetail) {
      link.setAttribute('data-barba-prevent', 'self');
    }
    link.addEventListener('click', function (e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      const navbar = document.querySelector('.navbar');
      const pageWrap = document.querySelector('.page-wrap');
      if (navbar) {
        navbar.style.transition = 'none';
        navbar.style.opacity = '1';
        navbar.style.visibility = 'visible';
      }
      const darkOverlay = document.createElement('div');
      Object.assign(darkOverlay.style, {
        position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh',
        backgroundColor: 'rgba(0, 0, 0, 0.6)', opacity: 0, zIndex: 9998, pointerEvents: 'none'
      });
      const transitionDiv = document.createElement('div');
      Object.assign(transitionDiv.style, {
        position: 'fixed', left: 0, right: 0, height: '100vh',
        backgroundColor: colorValue, zIndex: 9999, bottom: '-100vh', pointerEvents: 'none'
      });
      document.body.appendChild(darkOverlay);
      document.body.appendChild(transitionDiv);
      const tl = gsap.timeline({ defaults: { duration: 1.2, ease: 'power4.inOut' } });
      tl.to(darkOverlay, { opacity: 0.4 }, 0);
      tl.to(transitionDiv, { bottom: 0 }, 0);
      if (pageWrap) tl.to(pageWrap, { y: -40, opacity: 0.9 }, 0);
      tl.add(() => window.location.href = href);
    });
  });
}
function initDesktopServiceMenu() {
