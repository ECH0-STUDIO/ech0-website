/**
 * Improved Slot Machine Style Number Animation
 * For animating numbers with a sliding effect like a slot machine
 * With fixes for mobile devices and proper overflow handling
 */
// Main function to initialize the animation
function initSlotMachineAnimation(elementId, startNumber, endNumber, options = {}) {
  // Default options
  const defaultOptions = {
    duration: 1000,  // Animation duration in ms
    easing: 'cubic-bezier(0.16, 1, 0.3, 1)', // Ease out expo
    digitWidth: '0.6em', // Width of each digit container
    onComplete: null // Callback when animation completes
  };
  // Merge default options with provided options
  const config = { ...defaultOptions, ...options };
  // Convert numbers to strings and pad to the same length if needed
  const startStr = startNumber.toString();
  const endStr = endNumber.toString();
  // Get target element
  const targetElement = document.getElementById(elementId);
  if (!targetElement) {
    console.error(`Element with ID ${elementId} not found.`);
    return;
  }
  // Setup container styling
  targetElement.style.display = 'flex';
  targetElement.style.alignItems = 'center';
  targetElement.style.overflow = 'hidden';
  // Preserve original font size
  // Clear previous content
  targetElement.innerHTML = '';
  // Create and animate each digit
  for (let i = 0; i < endStr.length; i++) {
    const startDigit = i < startStr.length ? parseInt(startStr[startStr.length - endStr.length + i]) : 0;
    const endDigit = parseInt(endStr[i]);
    // Create container for this digit
    const digitContainer = document.createElement('div');
    digitContainer.style.position = 'relative';
    digitContainer.style.height = '1.2em'; // Use em to respect the parent font size
    digitContainer.style.width = config.digitWidth;
    digitContainer.style.overflow = 'hidden';
    digitContainer.style.display = 'inline-block';
    // Create the strip that will slide
    const digitStrip = document.createElement('div');
    digitStrip.style.position = 'absolute';
    digitStrip.style.left = '0';
    digitStrip.style.top = '0';
    digitStrip.style.width = '100%';
    digitStrip.style.display = 'flex';
    digitStrip.style.flexDirection = 'column';
    digitStrip.style.willChange = 'transform'; // Optimization for animation
    // Determine if this digit is counting up or down
    const isCountingUp = endDigit >= startDigit;
    // Generate all digits for the strip with clearer logic
    const digits = [];
    if (isCountingUp) {
      // For counting up (e.g., 0 to 9)
      for (let j = startDigit; j <= 9; j++) {
        digits.push(j);
      }
      if (endDigit !== 9) { // Only add the loop if we're not ending at 9
        for (let j = 0; j <= endDigit; j++) {
          digits.push(j);
        }
      }
    } else {
      // For counting down (e.g., 9 to 5)
      for (let j = startDigit; j >= 0; j--) {
        digits.push(j);
      }
      if (endDigit !== 0) { // Only add the loop if we're not ending at 0
        for (let j = 9; j >= endDigit; j--) {
          digits.push(j);
        }
      }
    }
    // Create elements for each digit in the strip
    digits.forEach(digit => {
      const digitElement = document.createElement('div');
      digitElement.style.height = '1.2em'; // Use em to respect the parent font size
      digitElement.style.width = '100%';
      digitElement.style.textAlign = 'center';
      digitElement.style.display = 'flex';
      digitElement.style.alignItems = 'center';
      digitElement.style.justifyContent = 'center';
      digitElement.textContent = digit;
      digitStrip.appendChild(digitElement);
    });
    // Add the strip to the container
    digitContainer.appendChild(digitStrip);
    // Add the container to the target element
    targetElement.appendChild(digitContainer);
    // Set initial position
    digitStrip.style.transform = 'translateY(0)';
    // Create and append an invisible digit to properly measure height
    const measureDigit = document.createElement('div');
    measureDigit.style.visibility = 'hidden';
    measureDigit.style.height = '1.2em';
    measureDigit.style.width = '100%';
    measureDigit.textContent = '0';
    // Clone font styles from target element to ensure accurate measurement
    const targetStyles = window.getComputedStyle(targetElement);
    measureDigit.style.fontFamily = targetStyles.fontFamily;
    measureDigit.style.fontSize = targetStyles.fontSize;
    measureDigit.style.fontWeight = targetStyles.fontWeight;
    document.body.appendChild(measureDigit);
    // Get the height of a single digit
    const digitHeight = parseFloat(window.getComputedStyle(measureDigit).height);
    document.body.removeChild(measureDigit);
    // Wait for next frame to ensure initial rendering before animation
    requestAnimationFrame(() => {
      // Calculate the final position
      const finalIndex = digits.lastIndexOf(endDigit);
      const finalOffset = -(finalIndex * digitHeight);
      // Apply transition
      digitStrip.style.transition = `transform ${config.duration}ms ${config.easing}`;
      // Move to final position with a slight buffer to ensure no overflow
      digitStrip.style.transform = `translateY(${finalOffset}px)`;
      // Handle animation completion for the last digit
      if (i === endStr.length - 1 && config.onComplete) {
        setTimeout(config.onComplete, config.duration);
      }
    });
  }
}
// Initialize the animation after a delay when your page loads
document.addEventListener('DOMContentLoaded', function() {
  // Set delay in milliseconds (e.g., 3000ms = 3 seconds)
  const delayBeforeAnimation = 2800;
  setTimeout(function() {
    initSlotMachineAnimation('ds-hero-number', 900, 599, {
      duration: 3000,
      digitWidth: '0.6em'  // Set explicit digit width
    });
  }, delayBeforeAnimation);
});
