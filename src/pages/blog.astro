---
import { sanityClient } from '../lib/sanity';

const blogs = await sanityClient.fetch(`*[_type == "blog"]{ 
  _id, 
  title, 
  "slug": slug.current, 
  smallThumbnailUrl, 
  metaDescription,
  _createdAt
}`);
