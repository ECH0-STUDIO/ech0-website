                            </svg></div>
                        </div>
                      </a>
                    </div>
                    <div class="spacer-24px"></div>
                    <h2 class="heading-style-h4">{blog.title}</h2>
                    <div class="spacer-12px"></div>
                    <div class="text-size-small">{new Date(blog._createdAt).toLocaleDateString()}</div>
                  </div>
