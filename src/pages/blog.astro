      0.2
    )
    .fromTo(".nav_services_block_line",
      { yPercent: -100 },
      { yPercent: 0, duration: 0.6, ease: "power2.out", stagger: 0.2 },
      0.3
    )
    .fromTo(".nav_services_closer",
      { opacity: 0 },
      { opacity: 1, duration: 0.5, ease: "power1.out" },
      0.3
    )
    .fromTo(".nav_services_card",
      { yPercent: -125 },
      { yPercent: 0, duration: 0.7, ease: "power2.out", stagger: 0.2 },
      0.5
    )
    .fromTo(".nav_services_block_img",
      { yPercent: 125 },
      { yPercent: 0, duration: 0.7, ease: "power2.out", stagger: 0.2 },
      0.5
    );
