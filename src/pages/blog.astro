          <div class="padding-global">
            <div class="w-layout-blockcontainer container-lg w-container">
              <h1 class="super-text">Blogs &amp; Insights</h1>
              <div class="spacer-64px"></div>
              <div class="w-dyn-list">
                <div role="list" class="blog_list w-dyn-items">
                  {blogs.map((blog: any) => (
                  <div role="listitem" class="blog_card w-dyn-item">
                    <div class="blog_card_img-wrap"><img src={blog.smallThumbnailUrl || "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"} loading="lazy" width="70" alt={blog.title} class="blog_card_img">
                      <a aria-label="View more of this News/Insight" internal-link="var(--background--light)" href={`/blog/${blog.slug}`} class="blog_card_img-link w-inline-block">
                        <div class="blog_card_img-link-btn">
                          <div class="blog_card_img-link-btn_ic w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 24 24" fill="none">
