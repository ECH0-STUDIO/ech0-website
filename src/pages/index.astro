---
import { sanityClient } from '../lib/sanity';

const allWorks = await sanityClient.fetch(`*[_type == "work"] { 
  _id, 
  title, 
  "slug": slug.current, 
  thumbnailUrl, 
  "categories": categories[]->name 
}`);
const works = allWorks.sort(() => Math.random() - 0.5).slice(0, 6);

const blogs = await sanityClient.fetch(`*[_type == "blog"] | order(_createdAt desc)[0...3] { 
  _id, 
  title, 
  "slug": slug.current, 
  smallThumbnailUrl, 
  _createdAt
}`);
