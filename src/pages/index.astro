document.addEventListener('DOMContentLoaded', function () {
    const video = document.querySelector('.h_video');
    const hero = document.querySelector('.h_hero');
    if (!video || !hero) return; // safety check
    function checkHeroScroll() {
        const heroRect = hero.getBoundingClientRect();
        const heroHeight = heroRect.height;
        // How much of hero is visible from the top?
        // When top <= -0.5 * height => scrolled out by 50%
        if (heroRect.top <= -0.5 * heroHeight) {
            video.classList.add('active');
            window.removeEventListener('scroll', checkHeroScroll);
        }
    }
    // Initial check in case page is loaded already scrolled
    checkHeroScroll();
    // Listen for scroll to check when to activate video
    window.addEventListener('scroll', checkHeroScroll);
});
