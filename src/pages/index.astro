          <script type="module">
import * as THREE from "https://threejsfundamentals.org/threejs/resources/threejs/r132/build/three.module.js";
import { GLTFLoader } from "https://threejsfundamentals.org/threejs/resources/threejs/r132/examples/jsm/loaders/GLTFLoader.js";
import { EffectComposer } from 'https://threejsfundamentals.org/threejs/resources/threejs/r132/examples/jsm/postprocessing/EffectComposer.js';
import { RenderPass } from 'https://threejsfundamentals.org/threejs/resources/threejs/r132/examples/jsm/postprocessing/RenderPass.js';
import { ShaderPass } from 'https://threejsfundamentals.org/threejs/resources/threejs/r132/examples/jsm/postprocessing/ShaderPass.js';
import { UnrealBloomPass } from 'https://threejsfundamentals.org/threejs/resources/threejs/r132/examples/jsm/postprocessing/UnrealBloomPass.js';
import { RGBShiftShader } from 'https://threejsfundamentals.org/threejs/resources/threejs/r132/examples/jsm/shaders/RGBShiftShader.js';
document.addEventListener("DOMContentLoaded", () => {
    const canvas = document.querySelector('.hero-webgl');
    const scene = new THREE.Scene();
    scene.background = new THREE.Color('#122D20');
    const sizes = {
        width: window.innerWidth,
        height: window.innerHeight
    };
    const matcapTexture = new THREE.TextureLoader().load("https://cdn.prod.website-files.com/67ec127269c9eeb8a38e34b1/68847e5a7aa5e71e79ceed2e_46PS9.jpg");
    const camera = new THREE.PerspectiveCamera(45, sizes.width / sizes.height, 0.1, 100);
    camera.position.set(0, 0, 10);
    scene.add(camera);
    const ambientLight = new THREE.AmbientLight(0x001122, 0.1);
    scene.add(ambientLight);
    scene.fog = new THREE.Fog('#122D20', -12, 2);
    scene.background = new THREE.Color('#122D20');
    const renderer = new THREE.WebGLRenderer({
        canvas: canvas,
        antialias: true,
        alpha: true
    });
    renderer.setSize(sizes.width, sizes.height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.outputEncoding = THREE.sRGBEncoding;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.9;
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    const bloomPass = new UnrealBloomPass(new THREE.Vector2(sizes.width, sizes.height), 0.4, 0.6, 0.85);
    composer.addPass(bloomPass);
    const aberrationPass = new ShaderPass(RGBShiftShader);
    aberrationPass.uniforms['amount'].value = 0.001;
    composer.addPass(aberrationPass);
    const VignetteShader = {
        uniforms: {
            tDiffuse: { value: null },
            offset: { value: 1.0 },
            darkness: { value: 1.2 }
        },
        vertexShader: `
            varying vec2 vUv;
            void main() {
                vUv = uv;
                gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
            }
        `,
        fragmentShader: `
            uniform float offset;
            uniform float darkness;
            uniform sampler2D tDiffuse;
            varying vec2 vUv;
            void main() {
                vec4 texel = texture2D(tDiffuse, vUv);
                vec2 uv = (vUv - vec2(0.5)) * vec2(offset);
                gl_FragColor = vec4(texel.rgb * (1.0 - dot(uv, uv) * darkness), texel.a);
            }
        `
    };
    composer.addPass(new ShaderPass(VignetteShader));
    window.addEventListener('resize', () => {
        sizes.width = window.innerWidth;
        sizes.height = window.innerHeight;
        camera.aspect = sizes.width / sizes.height;
        camera.updateProjectionMatrix();
        renderer.setSize(sizes.width, sizes.height);
        composer.setSize(sizes.width, sizes.height);
    });
    const loader = new GLTFLoader();
    function createFresnelMaterial(colorHex, bias, scale, intensity) {
        return new THREE.ShaderMaterial({
            uniforms: {
                uColor: { value: new THREE.Color(colorHex) },
                uBias: { value: bias },
                uScale: { value: scale },
                uIntensity: { value: intensity }
            },
            vertexShader: `
                varying float vFresnel;
                varying vec3 vNormal;
                varying vec3 vViewPosition;
                void main() {
                    vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
                    vViewPosition = -mvPosition.xyz;
                    vNormal = normalMatrix * normal;
                    gl_Position = projectionMatrix * mvPosition;
                }
            `,
            fragmentShader: `
                uniform vec3 uColor;
                uniform float uBias;
                uniform float uScale;
                uniform float uIntensity;
                varying vec3 vNormal;
                varying vec3 vViewPosition;
                void main() {
                    float fresnel = uBias + uScale * pow(1.0 - dot(normalize(vViewPosition), normalize(vNormal)), uIntensity);
                    gl_FragColor = vec4(uColor, fresnel);
                }
            `,
            transparent: true,
            depthWrite: false,
            depthTest: false,
            blending: THREE.AdditiveBlending
        });
    }
    function applyLayersToMesh(child) {
        // Base transparent material
        child.material = new THREE.MeshPhysicalMaterial({
            color: new THREE.Color(0x00ff44),
            metalness: 0.0,
            roughness: 0.0,
            transparent: true,
            opacity: 0.5,
            transmission: 0.0,
            thickness: 0.0,
            ior: 1.0,
            emissive: new THREE.Color(0x00ff44),
            emissiveIntensity: 1.0,
            side: THREE.DoubleSide,
            clearcoat: 1.0,
            clearcoatRoughness: 0.0
        });
        child.renderOrder = 0;
        // Matcap overlay
        if (matcapTexture.image) {
            const matcapMaterial = new THREE.MeshMatcapMaterial({
                matcap: matcapTexture,
                transparent: true,
                opacity: 0.1,
                depthWrite: false,
                depthTest: false,
                blending: THREE.CustomBlending,
                blendEquation: THREE.AddEquation,
                blendSrc: THREE.OneFactor,
                blendDst: THREE.OneFactor
            });
            const matcapMesh = child.clone();
            matcapMesh.material = matcapMaterial;
            matcapMesh.scale.multiplyScalar(1.001);
            matcapMesh.renderOrder = 1;
            child.parent.add(matcapMesh);
        }
        // Fresnel layers
        const fresnelOuter = child.clone();
        fresnelOuter.material = createFresnelMaterial('#4FFFB2', 0.1, 1.0, 1.5);
        fresnelOuter.scale.multiplyScalar(1.005);
        fresnelOuter.renderOrder = 3;
        child.parent.add(fresnelOuter);
        const fresnelInner = child.clone();
        fresnelInner.material = createFresnelMaterial('#1E8156', 0.1, 1.0, 1.2);
        fresnelInner.scale.multiplyScalar(1.002);
        fresnelInner.renderOrder = 2;
        child.parent.add(fresnelInner);
    }
    function createFallbackCrystal() {
        const geometry = new THREE.OctahedronGeometry(2, 2);
        const crystal = new THREE.Mesh(geometry);
        const pivot = new THREE.Group();
        pivot.add(crystal);
        scene.add(pivot);
        applyLayersToMesh(crystal);
        pivot.position.z = -10;
        pivot.position.y = 0.5;
        gsap.to(pivot.position, {
            z: -2,
            duration: 3,
            ease: "power2.out"
        });
        animateModel(pivot);
    }
    fetch("https://cdn.prod.website-files.com/67ec127269c9eeb8a38e34b1/68846d4c5068c92a75de2e60_crystal.glb.txt")
        .then(res => res.blob())
        .then(blob => {
            const blobUrl = URL.createObjectURL(blob);
            loader.load(blobUrl, (gltf) => {
                const model = gltf.scene;
                const box = new THREE.Box3().setFromObject(model);
                const center = box.getCenter(new THREE.Vector3());
                model.position.sub(center);
                model.traverse((child) => {
                    if (child.isMesh) {
                        applyLayersToMesh(child);
                    }
                });
                const pivot = new THREE.Group();
                pivot.add(model);
                scene.add(pivot);
                model.scale.set(1, 1, 1);
                pivot.position.z = -10;
                pivot.position.y = 0.25;
                gsap.to(pivot.position, {
                    z: -2,
                    duration: 3,
                    ease: "power2.out"
                });
                animateModel(pivot);
            }, undefined, (error) => {
                console.error("Failed to load GLB model, using fallback:", error);
                createFallbackCrystal();
            });
        })
        .catch(err => {
            console.error("Failed to fetch .glb.txt model, using fallback:", err);
            createFallbackCrystal();
        });
    function animateModel(pivot) {
        const clock = new THREE.Clock();
        function tick() {
            const elapsed = clock.getElapsedTime();
            pivot.rotation.y = elapsed * 1.0;
            composer.render();
            requestAnimationFrame(tick);
        }
        tick();
    }
});
</script>
