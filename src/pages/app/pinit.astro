      <div class="w-embed w-script"><!--  Page Load  -->
        <script>
  window.addEventListener('load', () => {
    gsap.registerPlugin(Flip);
    const originalWrap = document.querySelector('.pi_hero_logo-wrap_outer');
    const originalLogo = document.querySelector('.pi_hero_logo');
    if (!originalWrap || !originalLogo) return;
    // lock scroll
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
    const rect = originalWrap.getBoundingClientRect();
    // yellow overlay only
    const overlay = document.createElement('div');
    overlay.style.position = 'fixed';
    overlay.style.inset = '0';
    overlay.style.background = '#f7ff84';
    overlay.style.zIndex = '99999';
    overlay.style.pointerEvents = 'all';
    document.body.appendChild(overlay);
    // flying logo layer (SEPARATE from overlay)
    const flyingWrap = document.createElement('div');
    flyingWrap.style.position = 'fixed';
    flyingWrap.style.left = '50%';
    flyingWrap.style.top = '50%';
    flyingWrap.style.width = rect.width + 'px';
    flyingWrap.style.height = rect.height + 'px';
    flyingWrap.style.transform = 'translate(-50%, -50%)';
    flyingWrap.style.display = 'flex';
    flyingWrap.style.alignItems = 'center';
    flyingWrap.style.justifyContent = 'center';
    flyingWrap.style.zIndex = '100000';
    flyingWrap.style.pointerEvents = 'none';
    document.body.appendChild(flyingWrap);
    // clone only the logo
    const logoClone = originalLogo.cloneNode(true);
    logoClone.style.width = '100%';
    logoClone.style.height = '100%';
    logoClone.style.display = 'block';
    logoClone.style.opacity = '1';
    logoClone.style.visibility = 'visible';
    logoClone.style.transform = 'none';
    flyingWrap.appendChild(logoClone);
    // hide the real logo during intro
    gsap.set(originalWrap, { visibility: 'hidden' });
    // capture centered state
    const state = Flip.getState(flyingWrap);
    // set final state to real logo position
    gsap.set(flyingWrap, {
      left: rect.left,
      top: rect.top,
      width: rect.width,
      height: rect.height,
      x: 0,
      y: 0,
      clearProps: 'transform'
    });
    const tl = gsap.timeline({
      onComplete: () => {
        gsap.set(originalWrap, { visibility: 'visible' });
        flyingWrap.remove();
        overlay.remove();
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
      }
    });
    // hold centered for 1s
    tl.to({}, { duration: 1 });
    // start flight + overlay fade at same time
    tl.addLabel('fly');
    tl.add(
      Flip.from(state, {
        targets: flyingWrap,
        duration: 0.9,
        ease: 'power3.inOut',
        absolute: true,
        scale: true
      }),
      'fly'
    );
    tl.to(
      overlay,
      {
        opacity: 0,
        duration: 0.8, // slower fade
        ease: 'power1.out'
      },
      'fly+=0.9' // starts AFTER logo flight (duration = 0.9)
    );
  });
</script>
        <!--  Scene Transition  -->
        <script>
  document.addEventListener('DOMContentLoaded', () => {
    const logo = document.querySelector('.pi_hero_logo');
    const scene2Layer = document.querySelector('.pi-scene2-layer');
    const transitionCanvas = document.querySelector('.pi-transition-overlay');
    if (!logo || !scene2Layer || !transitionCanvas) return;
    const ctx = transitionCanvas.getContext('2d');
    if (!ctx) return;
    let open = false;
    let rafId = 0;
    let currentRadius = 0;
    function getLogoCenterInLayer() {
      const layerRect = scene2Layer.getBoundingClientRect();
      const logoRect = logo.getBoundingClientRect();
      return {
        x: logoRect.left - layerRect.left + logoRect.width * 0.5,
        y: logoRect.top - layerRect.top + logoRect.height * 0.5,
      };
    }
    function getMaxRadiusFromPoint(x, y) {
      const w = scene2Layer.clientWidth;
      const h = scene2Layer.clientHeight;
      return Math.max(Math.hypot(x, y), Math.hypot(w - x, y), Math.hypot(x, h - y), Math.hypot(w - x, h - y));
    }
    function setClip(radius, x, y) {
      currentRadius = radius;
      const value = `circle(${radius}px at ${x}px ${y}px)`;
      scene2Layer.style.clipPath = value;
      scene2Layer.style.webkitClipPath = value;
    }
    function easeInOutCubic(t) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }
    function resizeTransitionCanvas() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      transitionCanvas.width = Math.floor(scene2Layer.clientWidth * dpr);
      transitionCanvas.height = Math.floor(scene2Layer.clientHeight * dpr);
      transitionCanvas.style.width = `${scene2Layer.clientWidth}px`;
      transitionCanvas.style.height = `${scene2Layer.clientHeight}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function clearTransitionRipple() {
      ctx.clearRect(0, 0, scene2Layer.clientWidth, scene2Layer.clientHeight);
    }
    function drawTransitionRipple(cx, cy, radius, maxR, opening) {
      clearTransitionRipple();
      const progress = maxR > 0 ? radius / maxR : 0;
      const alpha = opening ? Math.max(0, 0.2 * (1 - progress)) : Math.max(0, 0.16 * progress);
      ctx.save();
      ctx.globalCompositeOperation = 'lighter';
      const glow = ctx.createRadialGradient(cx, cy, Math.max(0, radius - 70), cx, cy, radius + 30);
      glow.addColorStop(0.0, 'rgba(255,255,255,0)');
      glow.addColorStop(0.58, `rgba(255,255,255,${alpha})`);
      glow.addColorStop(0.76, `rgba(255,120,120,${alpha * 0.55})`);
      glow.addColorStop(0.88, `rgba(120,180,255,${alpha * 0.55})`);
      glow.addColorStop(1.0, 'rgba(255,255,255,0)');
      ctx.fillStyle = glow;
      ctx.beginPath();
      ctx.arc(cx, cy, radius + 36, 0, Math.PI * 2);
      ctx.fill();
      ctx.lineWidth = 2;
      ctx.strokeStyle = `rgba(255,255,255,${alpha * 0.9})`;
      ctx.beginPath();
      ctx.arc(cx, cy, radius, 0, Math.PI * 2);
      ctx.stroke();
      ctx.restore();
    }
    function animateScene2(nextOpen) {
      cancelAnimationFrame(rafId);
      const origin = getLogoCenterInLayer();
      const maxR = getMaxRadiusFromPoint(origin.x, origin.y);
      const startRadius = currentRadius;
      const endRadius = nextOpen ? maxR + 2 : 0;
      const duration = 850;
      const start = performance.now();
      scene2Layer.classList.add('is-visible');
      function frame(now) {
        const t = Math.min((now - start) / duration, 1);
        const e = easeInOutCubic(t);
        const radius = startRadius + (endRadius - startRadius) * e;
        setClip(radius, origin.x, origin.y);
        drawTransitionRipple(origin.x, origin.y, radius, maxR, nextOpen);
        if (t < 1) {
          rafId = requestAnimationFrame(frame);
          return;
        }
        open = nextOpen;
        clearTransitionRipple();
        if (!open) {
          scene2Layer.classList.remove('is-visible');
          setClip(0, origin.x, origin.y);
        } else {
          setClip(maxR + 2, origin.x, origin.y);
        }
      }
      rafId = requestAnimationFrame(frame);
    }
    resizeTransitionCanvas();
    const initialOrigin = getLogoCenterInLayer();
    setClip(0, initialOrigin.x, initialOrigin.y);
    logo.style.cursor = 'pointer';
    logo.addEventListener('pointerup', (e) => {
      e.preventDefault();
      animateScene2(!open);
    });
    window.addEventListener('resize', () => {
      resizeTransitionCanvas();
      const origin = getLogoCenterInLayer();
      const maxR = getMaxRadiusFromPoint(origin.x, origin.y);
      if (open) {
        setClip(maxR + 2, origin.x, origin.y);
      } else {
        setClip(0, origin.x, origin.y);
      }
      clearTransitionRipple();
    });
    window.addEventListener(
      'scroll',
      () => {
        const origin = getLogoCenterInLayer();
        const maxR = getMaxRadiusFromPoint(origin.x, origin.y);
        if (open) {
          setClip(maxR + 2, origin.x, origin.y);
        } else {
          setClip(0, origin.x, origin.y);
        }
      },
      { passive: true },
    );
  });
