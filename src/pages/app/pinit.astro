    g2.addColorStop(0.5, `rgba(255,120,120,${alpha * 0.12 * t.hueStrength})`);
    g2.addColorStop(1.0, `rgba(255,120,120,0)`);
    overlayCtx.fillStyle = g2;
    overlayCtx.beginPath();
