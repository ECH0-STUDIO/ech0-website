  <!--  INTERNAL LINK TRANSITION  -->
  <script>
document.addEventListener('DOMContentLoaded', function () {
    const internalLinks = document.querySelectorAll('[internal-link]');
    internalLinks.forEach(link => {
        const colorValue = link.getAttribute('internal-link');
        // Skip if attribute is empty
        if (!colorValue) return;
        link.addEventListener('click', function (e) {
            e.preventDefault();
            const navbar = document.querySelector('.navbar');
              if (navbar) {
                  navbar.style.transition = 'none';
                  navbar.style.opacity = '1';
                  navbar.style.visibility = 'visible';
              }
            const href = this.getAttribute('href');
            const pageWrap = document.querySelector('.page-wrap');
            // Create dark overlay div (fades in)
            const darkOverlay = document.createElement('div');
            darkOverlay.style.position = 'fixed';
            darkOverlay.style.left = 0;
            darkOverlay.style.top = 0;
            darkOverlay.style.width = '100vw';
            darkOverlay.style.height = '100vh';
            darkOverlay.style.backgroundColor = 'rgba(0, 0, 0, 0.6)';
            darkOverlay.style.opacity = 0;
            darkOverlay.style.zIndex = 9998;
            darkOverlay.style.pointerEvents = 'none';
            // Create color cover div (slides up)
            const transitionDiv = document.createElement('div');
            transitionDiv.style.position = 'fixed';
            transitionDiv.style.left = 0;
            transitionDiv.style.right = 0;
            transitionDiv.style.height = '100vh';
            transitionDiv.style.backgroundColor = colorValue;
            transitionDiv.style.zIndex = 9999;
            transitionDiv.style.bottom = '-100vh';
            transitionDiv.style.pointerEvents = 'none';
            // Append both overlays
            document.body.appendChild(darkOverlay);
            document.body.appendChild(transitionDiv);
            if (typeof gsap !== 'undefined') {
                const tl = gsap.timeline({
                    defaults: { duration: 1.2, ease: 'power4.inOut' }
                });
                // Animate darkOverlay fade in
                tl.to(darkOverlay, { opacity: 0.4 }, 0);
                // Slide color overlay up
                tl.to(transitionDiv, { bottom: 0 }, 0);
                // Move .page-wrap upward slightly
                if (pageWrap) {
                    tl.to(pageWrap, { y: -40, opacity: 0.9 }, 0);
                }
                // Navigate after animation
                tl.add(() => {
                    window.location.href = href;
                });
            } else {
                // Fallback (no GSAP)
                darkOverlay.style.transition = 'opacity 1.2s ease';
                darkOverlay.style.opacity = '0.4';
                transitionDiv.style.transition = 'bottom 1.2s ease';
                transitionDiv.style.bottom = '0';
                if (pageWrap) {
                    pageWrap.style.transition = 'transform 1.2s ease, opacity 1.2s ease';
                    pageWrap.style.transform = 'translateY(-40px)';
                    pageWrap.style.opacity = '0.9';
                }
                setTimeout(() => {
                    window.location.href = href;
                }, 1200);
            }
        });
    });
});
</script>
  <!--  FOOTER INTRO  -->
  <script>
  document.addEventListener("DOMContentLoaded", function () {
    gsap.registerPlugin(ScrollTrigger);
    const paths = Array.from(document.querySelectorAll(".footer-svg path"));
    // Sort paths by their x-position (visual order)
    const sortedPaths = paths.sort((a, b) => {
      return a.getBoundingClientRect().left - b.getBoundingClientRect().left;
    });
    gsap.fromTo(sortedPaths,
      { yPercent: 100, opacity: 0 },
      {
        yPercent: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
        stagger: 0.05,
        scrollTrigger: {
          trigger: ".footer-svg",
          start: "top bottom",
          toggleActions: "play none none none"
        }
      });
  });
</script>
