        <!--  Confirm Section Transition  -->
        <script>
  window.addEventListener('load', () => {
    gsap.registerPlugin(ScrollTrigger, SplitText);
    const section = document.querySelector('.pi_confirm');
    const mainText = document.querySelector('.pi_confirm_main-text');
    const secondaryText = document.querySelector('.pi_confirm_secondary-text');
    const graphics = [
      document.querySelector('.pi_confirm_graphic.is-1st'),
      document.querySelector('.pi_confirm_graphic.is-2nd'),
      document.querySelector('.pi_confirm_graphic.is-3rd')
    ];
    const content = [
      {
        main: 'What if I want to use Locket but want to keep it to myself?',
        secondary: 'Have you tried Pinit?',
      },
      {
        main: 'I want to save locations I visited for my friend to try when they travel here?',
        secondary: 'Ok. Pinit might help with that.',
      },
      {
        main: 'There is no internet here and my phone service ran out?',
        secondary: 'Yeah. Definitely Pinit!',
      },
    ];
    let activeIndex = -1;
    let currentMainSplit = null;
    let currentSecondarySplit = null;
    let currentTimeline = null;
    function wrapLines(splitInstance) {
      splitInstance.lines.forEach((line) => {
        const outer = document.createElement('div');
        outer.classList.add('pi-line-outer');
        const inner = document.createElement('div');
        inner.classList.add('pi-line-inner');
        line.parentNode.insertBefore(outer, line);
        outer.appendChild(inner);
        inner.appendChild(line);
      });
    }
    function splitElement(element) {
      const split = new SplitText(element, {
        type: 'lines',
        linesClass: 'pi-line',
      });
      wrapLines(split);
      const innerLines = element.querySelectorAll('.pi-line-inner');
      gsap.set(innerLines, {
        yPercent: 100,
        opacity: 0,
      });
      return {
        split,
        innerLines,
      };
    }
    function cleanupSplits() {
      if (currentMainSplit) currentMainSplit.split.revert();
      if (currentSecondarySplit) currentSecondarySplit.split.revert();
      currentMainSplit = null;
      currentSecondarySplit = null;
    }
    function buildState(index) {
      cleanupSplits();
      mainText.textContent = content[index].main;
      secondaryText.textContent = content[index].secondary;
      currentMainSplit = splitElement(mainText);
      currentSecondarySplit = splitElement(secondaryText);
    }
    function animateStateIn() {
      if (currentTimeline) currentTimeline.kill();
      currentTimeline = gsap.timeline();
      currentTimeline.to(
        currentMainSplit.innerLines,
        {
          yPercent: 0,
          opacity: 1,
          duration: 0.38,
          stagger: 0.08,
          ease: 'power3.out',
        },
        0
      );
      currentTimeline.to(
        currentSecondarySplit.innerLines,
        {
          yPercent: 0,
          opacity: 1,
          duration: 0.34,
          stagger: 0.06,
          ease: 'power3.out',
        },
        0.05
      );
    }
    function setGraphicsState(nextIndex, immediate = false) {
      graphics.forEach((graphic, index) => {
        if (!graphic) return;
        gsap.killTweensOf(graphic);
        if (index === nextIndex) {
          if (immediate) {
            gsap.set(graphic, {
              width: '100%',
              height: '100%',
            });
          } else {
            gsap.to(graphic, {
              width: '100%',
              height: '100%',
              duration: 0.35,
              ease: 'power2.out',
              overwrite: true,
            });
          }
        } else {
          if (immediate) {
            gsap.set(graphic, {
              width: '0%',
              height: '0%',
            });
          } else {
            gsap.to(graphic, {
              width: '0%',
              height: '0%',
              duration: 0.22,
              ease: 'power2.inOut',
              overwrite: true,
            });
          }
        }
      });
    }
    function goToState(index, immediate = false) {
      if (index === activeIndex && !immediate) return;
      if (currentTimeline) currentTimeline.kill();
      buildState(index);
      if (immediate) {
        gsap.set(currentMainSplit.innerLines, {
          yPercent: 0,
          opacity: 1,
        });
        gsap.set(currentSecondarySplit.innerLines, {
          yPercent: 0,
          opacity: 1,
        });
      } else {
        animateStateIn();
      }
      setGraphicsState(index, immediate);
      activeIndex = index;
    }
    function getIndexFromProgress(progress) {
      return Math.min(2, Math.floor(progress * 3));
    }
    // Initial graphic state: width/height only
    setGraphicsState(0, true);
    goToState(0, false);
    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      onUpdate: (self) => {
        const nextIndex = getIndexFromProgress(self.progress);
        goToState(nextIndex);
      },
    });
    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const currentIndex = activeIndex < 0 ? 0 : activeIndex;
        if (currentTimeline) currentTimeline.kill();
        cleanupSplits();
        mainText.textContent = content[currentIndex].main;
        secondaryText.textContent = content[currentIndex].secondary;
        currentMainSplit = splitElement(mainText);
        currentSecondarySplit = splitElement(secondaryText);
        gsap.set(currentMainSplit.innerLines, {
          yPercent: 0,
          opacity: 1,
        });
        gsap.set(currentSecondarySplit.innerLines, {
          yPercent: 0,
          opacity: 1,
        });
        setGraphicsState(currentIndex, true);
        ScrollTrigger.refresh();
      }, 150);
    });
  });
</script>
        <!--  FAQ  -->
        <script>
  window.addEventListener('load', () => {
    const faqItems = document.querySelectorAll('.pi_faq_item');
    let activeItem = null;
    // measure and collapse all answers on load
    faqItems.forEach((item) => {
      const answer = item.querySelector('.pi_faq_answer');
      const icon = item.querySelector('.pi_faq_question_ic');
      if (!answer) return;
      const originHeight = answer.scrollHeight;
      answer.setAttribute('origin-height', originHeight);
      answer.style.height = '0px';
      answer.style.overflow = 'hidden';
      answer.style.transition = 'height 0.3s ease';
      if (icon) icon.classList.remove('active');
    });
    faqItems.forEach((item) => {
      const question = item.querySelector('.pi_faq_question');
      const answer = item.querySelector('.pi_faq_answer');
      const icon = item.querySelector('.pi_faq_question_ic');
      if (!question || !answer) return;
      question.addEventListener('click', () => {
        const isOpen = activeItem === item;
        // close previous open item
        if (activeItem) {
          const prevAnswer = activeItem.querySelector('.pi_faq_answer');
          const prevIcon = activeItem.querySelector('.pi_faq_question_ic');
          if (prevAnswer) prevAnswer.style.height = '0px';
          if (prevIcon) prevIcon.classList.remove('active');
        }
        // if clicking the already-open item, just close it
        if (isOpen) {
          activeItem = null;
          return;
        }
        // open clicked item
        const savedHeight = answer.getAttribute('origin-height');
        answer.style.height = savedHeight + 'px';
        if (icon) icon.classList.add('active');
        activeItem = item;
      });
    });
  });
</script>
