document.addEventListener("DOMContentLoaded", function () {
  const trigger = document.getElementById("nav-mobile-trigger");
  const navMenu = document.getElementById("nav-mobile-menu");
  const navLogo = document.querySelector(".nav_logo-wrap");
  if (!trigger || !navMenu || !navLogo) return;
  function toggleMenu(isOpen) {
    trigger.classList.toggle("active", isOpen);
    navLogo.classList.toggle("active", isOpen);
    navMenu.classList.toggle("active", isOpen);
    if (isOpen) {
      navMenu.style.visibility = "visible";
      if (window.lenis) window.lenis.stop();
    } else {
      if (window.lenis) window.lenis.start();
      navMenu.addEventListener("transitionend", function handler(e) {
        if (e.propertyName === "opacity" && !navMenu.classList.contains("active")) {
          navMenu.style.visibility = "hidden";
          navMenu.removeEventListener("transitionend", handler);
        }
      });
    }
  }
  // Trigger click: toggle menu open/close
  trigger.addEventListener("click", function (e) {
    e.preventDefault();
    e.stopPropagation();
    const isOpen = navMenu.classList.contains("active");
    toggleMenu(!isOpen);
  });
  // Close menu when clicking outside of it
  document.addEventListener("click", function (e) {
    const clickedInsideMenu = e.target.closest("#nav-mobile-menu");
    if (!clickedInsideMenu && navMenu.classList.contains("active")) {
      toggleMenu(false);
    }
  });
});
</script>
  <!--  DYNAMIC NAVBAR THEME  -->
  <script>
document.addEventListener('DOMContentLoaded', () => {
  const navbar = document.querySelector('.navbar');
  const triggerLine1 = document.querySelector('.nav_mobile-trigger_line1');
  const triggerLine2 = document.querySelector('.nav_mobile-trigger_line2');
  let currentTheme = null;
  const OFFSET = 40; // 40px offset from top
  // Function to find which section is at the top with offset
  function getSectionAtTop() {
    const themeSections = document.querySelectorAll('[data-theme]');
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top <= OFFSET && rect.bottom > OFFSET) {
        return section;
      }
    }
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        return section;
      }
    }
    return null;
  }
  // Function to update navbar theme
  function updateNavbarTheme() {
    const topSection = getSectionAtTop();
    if (topSection) {
      const theme = topSection.getAttribute('data-theme');
      if (theme !== currentTheme) {
        currentTheme = theme;
        navbar.style.transition = 'background-color 0.3s, color 0.3s';
        if (theme === 'light') {
          navbar.style.backgroundColor = 'var(--background--light)';
          navbar.style.color = 'var(--text-color--primary-dark)';
          triggerLine1.style.backgroundColor = 'var(--background--dark)';
          triggerLine2.style.backgroundColor = 'var(--background--dark)';
        } else if (theme === 'dark') {
          navbar.style.backgroundColor = 'var(--background--dark)';
          navbar.style.color = 'var(--text-color--primary-light)';
          triggerLine1.style.backgroundColor = 'var(--background--light)';
          triggerLine2.style.backgroundColor = 'var(--background--light)';
        } else if (theme === 'transparent') {
          navbar.style.backgroundColor = 'transparent';
          navbar.style.color = 'var(--text-color--primary-light)';
          triggerLine1.style.backgroundColor = 'var(--background--light)';
          triggerLine2.style.backgroundColor = 'var(--background--light)';
        }
      }
    }
  }
  // Initial update
  updateNavbarTheme();
  // Throttled scroll event
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateNavbarTheme();
        ticking = false;
      });
      ticking = true;
    }
  });
});
</script>
