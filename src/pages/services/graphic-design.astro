document.addEventListener('DOMContentLoaded', function() {
    // Register ScrollTrigger plugin
    gsap.registerPlugin(ScrollTrigger);
    // Select all highlight elements
    const highlights = document.querySelectorAll('.text-highlight');
    // Create animation for each highlight
    highlights.forEach(highlight => {
        gsap.to(highlight, {
            backgroundSize: '100% 100%',
            ease: 'none', // Linear ease for smooth scrubbing
            scrollTrigger: {
                trigger: highlight,
                start: 'top bottom', // Triggers when element is 20% in view
                end: 'top 50%', // End position for the scrub
                scrub: 1, // Smooth scrubbing (1 second smoothing)
                // toggleActions: 'play none none reverse' // Removed as we're using scrub
            }
        });
    });
});
</script>
