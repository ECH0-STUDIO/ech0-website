        <script>
function initNavbarTheme() {
  const navbar = document.querySelector('.navbar');
  const triggerLine1 = document.querySelector('.nav_mobile-trigger_line1');
  const triggerLine2 = document.querySelector('.nav_mobile-trigger_line2');
  if (!navbar || !triggerLine1 || !triggerLine2) return; // prevent crash
  let currentTheme = null;
  const OFFSET = 40;
  function getSectionAtTop() {
    const themeSections = document.querySelectorAll('[data-theme]');
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top <= OFFSET && rect.bottom > OFFSET) return section;
    }
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) return section;
    }
    return null;
  }
  function updateNavbarTheme() {
    const topSection = getSectionAtTop();
    if (!topSection) return;
    const theme = topSection.getAttribute('data-theme');
    if (theme !== currentTheme) {
      currentTheme = theme;
      navbar.style.transition = 'background-color 0.3s, color 0.3s';
      if (theme === 'light') {
        navbar.style.backgroundColor = 'var(--background--light)';
        navbar.style.color = 'var(--text-color--primary-dark)';
        triggerLine1.style.backgroundColor = 'var(--background--dark)';
        triggerLine2.style.backgroundColor = 'var(--background--dark)';
      } else if (theme === 'dark') {
        navbar.style.backgroundColor = 'var(--background--dark)';
        navbar.style.color = 'var(--text-color--primary-light)';
        triggerLine1.style.backgroundColor = 'var(--background--light)';
        triggerLine2.style.backgroundColor = 'var(--background--light)';
      } else if (theme === 'transparent') {
        navbar.style.backgroundColor = 'transparent';
        navbar.style.color = 'var(--text-color--primary-light)';
        triggerLine1.style.backgroundColor = 'var(--background--light)';
        triggerLine2.style.backgroundColor = 'var(--background--light)';
      }
    }
  }
  updateNavbarTheme();
  window.addEventListener('scroll', () => {
    requestAnimationFrame(updateNavbarTheme);
  });
}
function initMobileMenu() {
  const trigger = document.querySelector(".nav_mobile-trigger");
  const navMenu = document.querySelector(".nav_mobile-menu");
  const navLogo = document.querySelector(".nav_logo-wrap");
  if (!trigger || !navMenu || !navLogo) return;
  function toggleMenu(isOpen) {
    trigger.classList.toggle("active", isOpen);
    navLogo.classList.toggle("active", isOpen);
    if (isOpen) {
      navMenu.classList.add("active");
      navMenu.style.visibility = "visible";
      if (window.lenis) window.lenis.stop();
    } else {
      navMenu.classList.remove("active");
      if (window.lenis) window.lenis.start();
      setTimeout(() => {
        if (!navMenu.classList.contains("active")) {
          navMenu.style.visibility = "hidden";
        }
      }, 500);
    }
  }
  document.addEventListener("click", function (e) {
    const isTrigger = trigger.contains(e.target);
    const isNavList = navMenu.contains(e.target);
    if (isTrigger) {
      const isActive = navMenu.classList.contains("active");
      toggleMenu(!isActive);
    } else if (!isNavList && navMenu.classList.contains("active")) {
      toggleMenu(false);
    }
  });
}
function initInternalLinks() {
  const links = document.querySelectorAll('[internal-link]');
  const isOnWorkDetail = document.querySelector('[data-barba-namespace="work-detail"]');
  links.forEach(link => {
    const colorValue = link.getAttribute('internal-link');
    if (!colorValue) return;
    // Prevent Barba from hijacking the link if on work-detail
    if (isOnWorkDetail) {
      link.setAttribute('data-barba-prevent', 'self');
    }
    link.addEventListener('click', function (e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      const navbar = document.querySelector('.navbar');
      const pageWrap = document.querySelector('.page-wrap');
      if (navbar) {
        navbar.style.transition = 'none';
        navbar.style.opacity = '1';
        navbar.style.visibility = 'visible';
      }
      const darkOverlay = document.createElement('div');
      Object.assign(darkOverlay.style, {
        position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh',
        backgroundColor: 'rgba(0, 0, 0, 0.6)', opacity: 0, zIndex: 9998, pointerEvents: 'none'
      });
      const transitionDiv = document.createElement('div');
      Object.assign(transitionDiv.style, {
        position: 'fixed', left: 0, right: 0, height: '100vh',
        backgroundColor: colorValue, zIndex: 9999, bottom: '-100vh', pointerEvents: 'none'
      });
      document.body.appendChild(darkOverlay);
      document.body.appendChild(transitionDiv);
      const tl = gsap.timeline({ defaults: { duration: 1.2, ease: 'power4.inOut' } });
      tl.to(darkOverlay, { opacity: 0.4 }, 0);
      tl.to(transitionDiv, { bottom: 0 }, 0);
      if (pageWrap) tl.to(pageWrap, { y: -40, opacity: 0.9 }, 0);
      tl.add(() => window.location.href = href);
    });
  });
}
function initDesktopServiceMenu() {
  if (window.innerWidth < 992) return;
  const wrap = document.querySelector('.nav_services_wrap');
  const openBtn = document.querySelector('#service-link');
  const closeBtn = document.querySelector('.nav_services_closer');
  if (!wrap || !openBtn || !closeBtn) return;
  const tl = gsap.timeline({ paused: true });
  tl.fromTo(".nav_services_header_line", { xPercent: -100 }, { xPercent: 0, duration: 0.6, ease: "power2.out" }, 0.2)
    .fromTo(".nav_services_block_line", { yPercent: -100 }, { yPercent: 0, duration: 0.6, ease: "power2.out", stagger: 0.2 }, 0.3)
    .fromTo(".nav_services_closer", { opacity: 0 }, { opacity: 1, duration: 0.5, ease: "power1.out" }, 0.3)
    .fromTo(".nav_services_card", { yPercent: -125 }, { yPercent: 0, duration: 0.7, ease: "power2.out", stagger: 0.2 }, 0.5)
    .fromTo(".nav_services_block_img", { yPercent: 125 }, { yPercent: 0, duration: 0.7, ease: "power2.out", stagger: 0.2 }, 0.5);
  openBtn.addEventListener('click', (e) => {
    e.preventDefault();
    wrap.classList.add('active');
    tl.play(0);
  });
  closeBtn.addEventListener('click', () => {
    tl.reverse();
    tl.eventCallback("onReverseComplete", () => {
      wrap.classList.remove('active');
    });
  });
}
</script>
        <!--  BARBAJS TRANSITION  -->
        <script src="https://unpkg.com/@barba/core"></script>
        <script>
console.log('[Barba] Script loaded');
// Prevent browser from auto-restoring scroll position
window.history.scrollRestoration = 'manual';
// Simple scroll lock functions
function lockScroll() {
  // Disable Lenis if it exists
  if (window.lenis) {
    window.lenis.stop();
  }
  // Prevent scroll events
  document.addEventListener('wheel', preventScroll, { passive: false });
  document.addEventListener('touchmove', preventScroll, { passive: false });
  document.addEventListener('keydown', preventScrollKeys, { passive: false });
  // Lock body scroll
  document.body.style.overflow = 'hidden';
  document.documentElement.style.overflow = 'hidden';
}
function unlockScroll() {
  // Re-enable Lenis if it exists
  if (window.lenis) {
    window.lenis.start();
  }
  // Remove event listeners
  document.removeEventListener('wheel', preventScroll);
  document.removeEventListener('touchmove', preventScroll);
  document.removeEventListener('keydown', preventScrollKeys);
  // Unlock body scroll
  document.body.style.overflow = '';
  document.documentElement.style.overflow = '';
}
function preventScroll(e) {
  e.preventDefault();
  e.stopPropagation();
  return false;
}
function preventScrollKeys(e) {
  const keys = [32, 33, 34, 35, 36, 37, 38, 39, 40]; // space, page up/down, end, home, arrow keys
  if (keys.includes(e.keyCode)) {
    e.preventDefault();
    return false;
  }
}
barba.init({
  debug: true,
  scroll: false,
  transitions: [
    {
      name: 'works-to-detail',
      from: { namespace: ['works'] },
      to: { namespace: ['work-detail'] },
      // Only apply this transition to elements with data-image-id
      custom: ({ trigger }) => {
        return trigger && trigger.hasAttribute('data-image-id');
      },
      async leave(data) {
        console.log('[Barba] leave works → detail');
        // 🔒 LOCK SCROLL IMMEDIATELY
        lockScroll();
        const done = this.async();
        const imageId = data.trigger?.dataset?.imageId;
        const fromImage = data.current.container.querySelector(`img[data-image-id="${imageId}"]`);
        if (!fromImage) {
          unlockScroll(); // Unlock if no image found
          return done();
        }
        // Measure position BEFORE any changes
        const rect = fromImage.getBoundingClientRect();
        // Clone the image
        const clone = fromImage.cloneNode(true);
        Object.assign(clone.style, {
          position: 'fixed',
          top: `${rect.top}px`,
          left: `${rect.left}px`,
          width: `${rect.width}px`,
          height: `${rect.height}px`,
          zIndex: 9999,
          objectFit: 'cover',
          pointerEvents: 'none',
          margin: 0
        });
        document.body.appendChild(clone);
        data.clone = clone;
        data.imageId = imageId;
        // Create overlay
        const overlay = document.createElement('div');
        Object.assign(overlay.style, {
          position: 'fixed',
          top: 0,
          left: 0,
          width: '100vw',
          height: '100vh',
          backgroundColor: 'var(--background--light)',
          opacity: 0,
          zIndex: 9998,
          pointerEvents: 'none'
        });
        overlay.classList.add('barba-transition-overlay');
        document.body.appendChild(overlay);
        data.overlay = overlay;
        // Animate overlay fade-in
        await gsap.to(overlay, {
          opacity: 1,
          duration: 0.3,
          ease: 'power2.out'
        });
        // Force body background
        document.body.style.setProperty('background-color', 'var(--background--light)', 'important');
        // Scroll to top AFTER locking scroll
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        // Begin fading out current container
        data.current.container.classList.add('barba-container-transitioning');
        await gsap.to(data.current.container, {
          opacity: 0,
          duration: 0.3,
          ease: 'power2.out'
        });
        done();
      },
      async enter(data) {
        console.log('[Barba] enter work-detail');
        const nextContainer = data.next.container;
        const clone = data.clone;
        const imageId = data.imageId;
        // Keep scroll locked during enter phase
        if (!clone || !imageId) {
          gsap.set(nextContainer, { opacity: 1 });
          // 🔓 UNLOCK SCROLL
          unlockScroll();
          return;
        }
        gsap.set(nextContainer, { opacity: 0 });
        let toImage = null;
        for (let i = 0; i < 15; i++) {
          await new Promise(r => setTimeout(r, 66));
          toImage = data.next.container.querySelector(`img.is-work[data-image-id="${imageId}"]`);
          if (toImage) break;
        }
        if (!toImage) {
          clone.remove();
          data.overlay?.remove();
          gsap.set(nextContainer, { opacity: 1 });
          // 🔓 UNLOCK SCROLL
          unlockScroll();
          return;
        }
        
        // Wait for image to load to guarantee correct height
        if (!toImage.complete) {
          await new Promise((resolve) => {
            toImage.addEventListener('load', resolve);
            toImage.addEventListener('error', resolve);
            setTimeout(resolve, 1500); // fallback timeout
          });
        }
        
        await new Promise(resolve => requestAnimationFrame(resolve));
        const rect = toImage.getBoundingClientRect();
        
        // Final sanity check, if it's somehow completely hidden just fallback
        if (rect.height === 0) {
          clone.remove();
          data.overlay?.remove();
          gsap.set(nextContainer, { opacity: 1 });
          unlockScroll();
          return;
        }
        await gsap.to(clone, {
          top: rect.top,
          left: rect.left,
          width: rect.width,
          height: rect.height,
          duration: 0.7,
          ease: 'power2.inOut'
        });
        await gsap.to(nextContainer, {
          opacity: 1,
          duration: 0.4,
          ease: 'power2.out'
        });
        clone.remove();
        data.overlay?.remove();
        // 🔓 UNLOCK SCROLL - Wait a bit to ensure everything is settled
        setTimeout(() => {
          unlockScroll();
        }, 100);
      }
    }
  ],
  prevent: ({ el, current }) => {
    const fromNamespace = current?.namespace;
    // Only prevent if leaving from work-detail (your original logic)
    if (fromNamespace === 'work-detail') {
      console.log('[Barba] Prevented: Leaving work-detail, fallback to default browser');
      return true;
    }
    // Let Barba handle links with data-image-id, prevent everything else
    if (el && !el.hasAttribute('data-image-id')) {
      console.log('[Barba] Prevented: Not an image link, using default navigation');
      return true;
    }
    return false;
  }
});
// Safety cleanup hooks
barba.hooks.afterEnter((data) => {

    // FORCE NAVBAR THEME FOR NEW PAGE
    const nextSection = data.next.container.querySelector('[data-theme]');
    if (nextSection) {
