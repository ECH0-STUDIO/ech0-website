---
import { sanityClient } from '../../lib/sanity';
const allWorks = await sanityClient.fetch(`*[_type == "work" && count((categories[]->name)[@ in ["Marketing graphics", "Branding", "2D animation", "Logo"]]) > 0]{
  _id,
  title,
  "slug": slug.current,
  thumbnailUrl,
  "categories": categories[]->name
}`);
const shuffledWorks = allWorks.sort(() => 0.5 - Math.random());
const works = shuffledWorks.slice(0, 3);
