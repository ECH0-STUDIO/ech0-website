//NAV MENU TRIGGER
document.addEventListener("DOMContentLoaded", function () {
  const trigger = document.getElementById("nav-mobile-trigger");
  const navMenu = document.getElementById("nav-mobile-menu");
  const navLogo = document.querySelector(".nav_logo-wrap");
  if (!trigger || !navMenu || !navLogo) return;
  function toggleMenu(isOpen) {
    trigger.classList.toggle("active", isOpen);
    navLogo.classList.toggle("active", isOpen);
    navMenu.classList.toggle("active", isOpen);
    if (isOpen) {
      navMenu.style.visibility = "visible";
      if (window.lenis) window.lenis.stop();
    } else {
      if (window.lenis) window.lenis.start();
      navMenu.addEventListener("transitionend", function handler(e) {
        if (e.propertyName === "opacity" && !navMenu.classList.contains("active")) {
          navMenu.style.visibility = "hidden";
          navMenu.removeEventListener("transitionend", handler);
        }
      });
    }
  }
  // Trigger click: toggle menu open/close
  trigger.addEventListener("click", function (e) {
    e.preventDefault();
    e.stopPropagation();
    const isOpen = navMenu.classList.contains("active");
    toggleMenu(!isOpen);
  });
  // Close menu when clicking outside of it
  document.addEventListener("click", function (e) {
    const clickedInsideMenu = e.target.closest("#nav-mobile-menu");
    if (!clickedInsideMenu && navMenu.classList.contains("active")) {
      toggleMenu(false);
    }
  });
});
</script>
  <!--  DYNAMIC NAVBAR THEME  -->
  <script>
document.addEventListener('DOMContentLoaded', () => {
  const navbar = document.querySelector('.navbar');
  const triggerLine1 = document.querySelector('.nav_mobile-trigger_line1');
  const triggerLine2 = document.querySelector('.nav_mobile-trigger_line2');
  let currentTheme = null;
  const OFFSET = 40; // 40px offset from top
  // Function to find which section is at the top with offset
  function getSectionAtTop() {
    const themeSections = document.querySelectorAll('[data-theme]');
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top <= OFFSET && rect.bottom > OFFSET) {
        return section;
      }
    }
    for (const section of themeSections) {
      const rect = section.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        return section;
      }
    }
    return null;
  }
  // Function to update navbar theme
  function updateNavbarTheme() {
    const topSection = getSectionAtTop();
    if (topSection) {
      const theme = topSection.getAttribute('data-theme');
      if (theme !== currentTheme) {
        currentTheme = theme;
        navbar.style.transition = 'background-color 0.3s, color 0.3s';
        if (theme === 'light') {
          navbar.style.backgroundColor = 'var(--background--light)';
          navbar.style.color = 'var(--text-color--primary-dark)';
          triggerLine1.style.backgroundColor = 'var(--background--dark)';
          triggerLine2.style.backgroundColor = 'var(--background--dark)';
        } else if (theme === 'dark') {
          navbar.style.backgroundColor = 'var(--background--dark)';
          navbar.style.color = 'var(--text-color--primary-light)';
          triggerLine1.style.backgroundColor = 'var(--background--light)';
          triggerLine2.style.backgroundColor = 'var(--background--light)';
        } else if (theme === 'transparent') {
          navbar.style.backgroundColor = 'transparent';
          navbar.style.color = 'var(--text-color--primary-light)';
          triggerLine1.style.backgroundColor = 'var(--background--light)';
          triggerLine2.style.backgroundColor = 'var(--background--light)';
        }
      }
    }
  }
  // Initial update
  updateNavbarTheme();
  // Throttled scroll event
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateNavbarTheme();
        ticking = false;
      });
      ticking = true;
    }
  });
});
</script>
  <!--  DESKTOP SERVICE MENU  -->
  <script>
document.addEventListener('DOMContentLoaded', () => {
  if (window.innerWidth >= 992) {
    const wrap = document.querySelector('.nav_services_wrap');
    const openBtn = document.querySelector('#service-link');
    const closeBtn = document.querySelector('.nav_services_closer');
    const tl = gsap.timeline({ paused: true });
    // Animation timeline
    tl.fromTo(".nav_services_header_line",
      { xPercent: -100 },
      { xPercent: 0, duration: 0.6, ease: "power2.out" },
      0.2
    )
    .fromTo(".nav_services_block_line",
      { yPercent: -100 },
      { yPercent: 0, duration: 0.6, ease: "power2.out", stagger: 0.2 },
      0.3
    )
    .fromTo(".nav_services_closer",
      { opacity: 0 },
      { opacity: 1, duration: 0.5, ease: "power1.out" },
      0.3
    )
    .fromTo(".nav_services_card",
      { yPercent: -125 },
      { yPercent: 0, duration: 0.7, ease: "power2.out", stagger: 0.2 },
      0.5
    )
    .fromTo(".nav_services_block_img",
      { yPercent: 125 },
      { yPercent: 0, duration: 0.7, ease: "power2.out", stagger: 0.2 },
      0.5
    );
    // Open animation
    openBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      wrap?.classList.add('active');
      tl.play(0);
    });
    // Close animation
    closeBtn?.addEventListener('click', () => {
      tl.reverse();
      tl.eventCallback("onReverseComplete", () => {
        wrap?.classList.remove('active');
      });
    });
  }
});
</script>
  <!--  INTERNAL LINK TRANSITION  -->
  <script>
document.addEventListener('DOMContentLoaded', function () {
    const internalLinks = document.querySelectorAll('[internal-link]');
    internalLinks.forEach(link => {
        const colorValue = link.getAttribute('internal-link');
        // Skip if attribute is empty
        if (!colorValue) return;
        link.addEventListener('click', function (e) {
            e.preventDefault();
            const navbar = document.querySelector('.navbar');
              if (navbar) {
                  navbar.style.transition = 'none';
                  navbar.style.opacity = '1';
                  navbar.style.visibility = 'visible';
              }
            const href = this.getAttribute('href');
            const pageWrap = document.querySelector('.page-wrap');
            // Create dark overlay div (fades in)
            const darkOverlay = document.createElement('div');
            darkOverlay.style.position = 'fixed';
            darkOverlay.style.left = 0;
            darkOverlay.style.top = 0;
            darkOverlay.style.width = '100vw';
            darkOverlay.style.height = '100vh';
            darkOverlay.style.backgroundColor = 'rgba(0, 0, 0, 0.6)';
            darkOverlay.style.opacity = 0;
            darkOverlay.style.zIndex = 9998;
            darkOverlay.style.pointerEvents = 'none';
            // Create color cover div (slides up)
            const transitionDiv = document.createElement('div');
            transitionDiv.style.position = 'fixed';
            transitionDiv.style.left = 0;
            transitionDiv.style.right = 0;
            transitionDiv.style.height = '100vh';
            transitionDiv.style.backgroundColor = colorValue;
            transitionDiv.style.zIndex = 9999;
            transitionDiv.style.bottom = '-100vh';
            transitionDiv.style.pointerEvents = 'none';
            // Append both overlays
            document.body.appendChild(darkOverlay);
            document.body.appendChild(transitionDiv);
            if (typeof gsap !== 'undefined') {
                const tl = gsap.timeline({
                    defaults: { duration: 1.2, ease: 'power4.inOut' }
                });
                // Animate darkOverlay fade in
                tl.to(darkOverlay, { opacity: 0.4 }, 0);
                // Slide color overlay up
                tl.to(transitionDiv, { bottom: 0 }, 0);
                // Move .page-wrap upward slightly
                if (pageWrap) {
                    tl.to(pageWrap, { y: -40, opacity: 0.9 }, 0);
                }
                // Navigate after animation
                tl.add(() => {
                    window.location.href = href;
                });
            } else {
                // Fallback (no GSAP)
                darkOverlay.style.transition = 'opacity 1.2s ease';
                darkOverlay.style.opacity = '0.4';
                transitionDiv.style.transition = 'bottom 1.2s ease';
                transitionDiv.style.bottom = '0';
                if (pageWrap) {
                    pageWrap.style.transition = 'transform 1.2s ease, opacity 1.2s ease';
                    pageWrap.style.transform = 'translateY(-40px)';
                    pageWrap.style.opacity = '0.9';
                }
                setTimeout(() => {
                    window.location.href = href;
                }, 1200);
            }
        });
    });
});
</script>
  <!--  FOOTER INTRO  -->
  <script>
  document.addEventListener("DOMContentLoaded", function () {
    gsap.registerPlugin(ScrollTrigger);
    const paths = Array.from(document.querySelectorAll(".footer-svg path"));
    // Sort paths by their x-position (visual order)
    const sortedPaths = paths.sort((a, b) => {
      return a.getBoundingClientRect().left - b.getBoundingClientRect().left;
    });
    gsap.fromTo(sortedPaths,
      { yPercent: 100, opacity: 0 },
      {
        yPercent: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
        stagger: 0.05,
        scrollTrigger: {
          trigger: ".footer-svg",
          start: "top bottom",
          toggleActions: "play none none none"
        }
      });
  });
</script>
